<mujoco model="QuadPayload">
  <include file="scene.xml"/>
  <compiler angle="degree" coordinate="local" inertiafromgeom="false"/>

  <worldbody>
    <body name="quadrotor" pos="0 0 3" quat="1 0 0 0">
      <inertial pos="0 0 0" mass="0.75" diaginertia="0.0053 0.0049 0.0098"/>
      <joint name="root_joint" type="free"/>
      <!-- Body -->
      <geom name="geom" type="box" pos="0 0 0" size="0.08 0.04 0.025" rgba="0.15 0.15 0.15 1"/>
      <site name="end1" pos="0 0 0" type="sphere" size="0.01" rgba="0 0 0 0"/>
      <!-- Arms -->
      <geom name="rotor_arm_geom_0" type="box" pos="0 0 0"
        quat="0.92388 0 0 0.382683" size="0.2 0.01 0.01" rgba="0.4 0.4 0.45 1"/>
      <geom name="rotor_arm_geom_1" type="box" pos="0 0 0"
        quat="0.382683 0 0 0.92388" size="0.2 0.01 0.01" rgba="0.4 0.4 0.45 1"/>
      <geom name="rotor_arm_geom_2" type="box" pos="0 0 0"
        quat="-0.382683 0 0 0.92388" size="0.2 0.01 0.01" rgba="0.4 0.4 0.45 1"/>
      <geom name="rotor_arm_geom_3" type="box" pos="0 0 0"
        quat="-0.92388 0 0 0.382683" size="0.2 0.01 0.01" rgba="0.4 0.4 0.45 1"/>
      <!-- Propellers -->
      <geom name="rotor_prop_geom_0" type="cylinder" size="0.1 0.005"
        pos="0.14142 0.14142 0" rgba="0.95 0.45 0.1 1"/>
      <geom name="rotor_prop_geom_1" type="cylinder" size="0.1 0.005"
        pos="-0.14142 0.14142 0" rgba="0.95 0.45 0.1 1"/>
      <geom name="rotor_prop_geom_2" type="cylinder" size="0.1 0.005"
        pos="-0.14142 -0.14142 0" rgba="0.95 0.45 0.1 1"/>
      <geom name="rotor_prop_geom_3" type="cylinder" size="0.1 0.005"
        pos="0.14142 -0.14142 0" rgba="0.95 0.45 0.1 1"/>
      <!-- Actuator sites (invisible) -->
      <site name="site0" pos="0.14142 0.14142 0" size="0.005" rgba="0 0 0 0"/>
      <site name="site1" pos="-0.14142 0.14142 0" size="0.005" rgba="0 0 0 0"/>
      <site name="site2" pos="-0.14142 -0.14142 0" size="0.005" rgba="0 0 0 0"/>
      <site name="site3" pos="0.14142 -0.14142 0" size="0.005" rgba="0 0 0 0"/>
      <site name="quadrotor_thrust" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
      <site name="quadrotor_Mx" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
      <site name="quadrotor_My" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
      <site name="quadrotor_Mz" pos="0 0 0" size="0.005" rgba="0 0 0 0"/>
    </body>
    <!-- Payload -->
    <body name="payload" pos="0 0 2" quat="1 0 0 0">
      <inertial pos="0 0 0" mass="0.15" diaginertia="0.00015 0.00015 0.00015"/>
      <geom type="sphere" pos="0 0 0" size="0.05" rgba="0.2 0.8 0.4 1"/>
      <site name="end2" pos="0 0 0" type="sphere" size="0.01" rgba="0 0 0 0"/>
      <joint type="free"/>
    </body>
  </worldbody>

  <actuator>
    <motor ctrllimited="true" site="site0" ctrlrange="0 10" gear="0 0 1 0 0 -0.025"/>
    <motor ctrllimited="true" site="site1" ctrlrange="0 10" gear="0 0 1 0 0  0.025"/>
    <motor ctrllimited="true" site="site2" ctrlrange="0 10" gear="0 0 1 0 0 -0.025"/>
    <motor ctrllimited="true" site="site3" ctrlrange="0 10" gear="0 0 1 0 0  0.025"/>
    <motor ctrllimited="true" site="quadrotor_thrust" ctrlrange="0 40" gear="0 0 1 0 0 0"/>
    <motor ctrllimited="true" site="quadrotor_Mx" ctrlrange="-3 3" gear="0 0 0 1 0 0"/>
    <motor ctrllimited="true" site="quadrotor_My" ctrlrange="-3 3" gear="0 0 0 0 1 0"/>
    <motor ctrllimited="true" site="quadrotor_Mz" ctrlrange="-3 3" gear="0 0 0 0 0 1"/>
  </actuator>

  <tendon>
    <spatial limited="true" range="0 1.0" damping="0" stiffness="0" width="0.003"
      rgba="0.9 0.9 0.9 1">
      <site site="end1"/>
      <site site="end2"/>
    </spatial>
  </tendon>
</mujoco>
